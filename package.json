    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "dev": "tsc -p ./ && cp -r out ~/.vscode/extensions/chuccv.magento-helper-1.0.0/"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.75.0",
        "typescript": "^5.4.0"
    }
