        "configuration": {
            "title": "Magento Helper",
            "properties": {
                "magentoHelper.searchPaths": {
                    "type": "array",
                    "default": [
                        "app/code",
                        "app/design",
                        "vendor/magento",
                        "vendor/hyva-themes",
                        "generated/code"
                    ],
                    "description": "Directories (relative to workspace) to scan for Magento XML/PHP files"
                },
                "magentoHelper.cli.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Master switch for the M2-CLI integration (status bar + auto checks). Status bar is also auto-hidden when the workspace is not a Magento project."
                },
                "magentoHelper.cli.command": {
                    "type": "string",
                    "default": "bin/magento",
                    "description": "Magento CLI executor prefix. Examples: 'bin/magento', 'ddev magento', 'docker compose exec php bin/magento'."
                },
                "magentoHelper.cli.autoDetectDdev": {
                    "type": "boolean",
                    "default": true,
                    "description": "If cli.command is the default and a .ddev/config.yaml is present in the workspace root, use 'ddev magento' automatically."
                },
                "magentoHelper.cli.defaultRunMode": {
                    "type": "string",
                    "enum": [
                        "terminal",
                        "silent"
                    ],
                    "default": "terminal",
                    "description": "Default mode for running Magento CLI commands. 'terminal' opens an integrated terminal; 'silent' runs in background, streams to the 'Magento CLI' Output Channel, and shows progress in the status bar."
                },
                "magentoHelper.cli.cwd": {
                    "type": "string",
                    "default": "",
                    "description": "Working directory for the Magento CLI. Empty means workspace root. May be absolute or relative to the workspace."
                },
                "magentoHelper.cli.statusBar.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show Magento deploy mode and maintenance status in the status bar."
                },
                "magentoHelper.tailwind.themePath": {
                    "type": "string",
                    "default": "",
                    "description": "Theme path (workspace-relative or absolute) used by the Tailwind build/watch commands. Either a theme root (e.g. 'app/design/frontend/Vendor/theme') or the tailwind dir itself. Empty = prompt and remember on first run."
                },
                "magentoHelper.cli.statusBar.refreshIntervalSec": {
                    "type": "number",
                    "default": 60,
                    "description": "How often (in seconds) to refresh the Magento status bar. 0 disables periodic refresh."
                }
            }
        }
